---
import PhilosophyPillars from "@components/interactive/PhilosophyPillars.tsx";
import type { Pillar } from "@components/interactive/PhilosophyPillars.tsx";

const pillars: Pillar[] = [
  {
    number: "01",
    title: "Crecimiento Constante",
    description:
      "Mi experiencia en logística me enseñó que un sistema sin optimización muere. Tu sitio recibe mejoras continuas de SEO y rendimiento, siempre.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    colorLight: "#16A34A",
    colorDark: "#4ADE80",
  },
  {
    number: "02",
    title: "Cero Fricción",
    description:
      "Tú plasmas tu visión, yo me encargo de la complejidad técnica. No necesitas saber de código para tener una presencia digital de clase mundial.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    colorLight: "#0891B2",
    colorDark: "#22D3EE",
  },
  {
    number: "03",
    title: "Estándares Mundiales",
    description:
      "Años trabajando para empresas en USA me obligaron a dominar las mejores prácticas globales de rendimiento y SEO. Eso es lo que aplico en cada proyecto.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20A14.5 14.5 0 0 0 12 2"/><path d="M2 12h20"/></svg>`,
    colorLight: "#7C3AED",
    colorDark: "#A78BFA",
  },
];
---

<section
  id="filosofia"
  class="relative overflow-hidden bg-[#E5F7FA] py-24 dark:bg-[#0B1519]"
  aria-labelledby="filosofia-heading"
>
  <!-- Orb derecho -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute right-0 top-1/2 h-[36rem] w-[36rem] -translate-y-1/2 translate-x-1/3 rounded-full bg-cyan-400/20 blur-3xl dark:bg-cyan-500/14"
  ></div>
  <!-- Orb izquierdo sutil -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-0 top-0 h-64 w-64 -translate-x-1/2 -translate-y-1/2 rounded-full bg-green-400/15 blur-3xl dark:bg-green-500/10"
  ></div>

  <div class="relative mx-auto max-w-6xl px-6">
    <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">

      <!-- Columna izquierda: cita editorial -->
      <div>
        <p class="mb-6 text-xs font-semibold tracking-[0.2em] uppercase text-cyan-700 dark:text-cyan-400">
          Filosofía
        </p>

        <!-- Comilla decorativa grande -->
        <div
          aria-hidden="true"
          class="font-display mb-2 text-[9rem] font-black leading-none text-green-500/15 dark:text-green-400/15 select-none"
        >
          "
        </div>

        <blockquote class="-mt-6">
          <p
            id="filosofia-heading"
            class="font-display text-4xl font-extrabold tracking-tight leading-[1.05] text-zinc-900 sm:text-5xl dark:text-zinc-50"
          >
            Un proyecto no se termina,<br />
            <span class="text-cyan-700 dark:text-cyan-400">
              se cultiva.
            </span>
          </p>
          <footer class="mt-5">
            <p class="text-sm text-zinc-500 dark:text-zinc-400">
              — El principio que guía cada decisión en Nicrosil
            </p>
          </footer>
        </blockquote>

        <!-- Descripción -->
        <p class="mt-8 max-w-md text-base leading-relaxed text-zinc-500 lg:text-lg dark:text-zinc-400">
          Un jardín que no se riega muere. Tu presencia digital funciona igual.
          La diferencia entre un sitio que crece y uno que queda obsoleto es la
          atención constante, no el lanzamiento inicial.
        </p>

        <!-- Separador decorativo -->
        <div class="mt-10 flex items-center gap-3">
          <div class="h-px w-10 bg-gradient-to-r from-green-500 to-cyan-500 dark:from-green-400 dark:to-cyan-400"></div>
          <div class="h-1.5 w-1.5 rounded-full bg-green-500 dark:bg-green-400"></div>
          <div class="h-px flex-1 bg-gradient-to-r from-cyan-500/50 to-transparent dark:from-cyan-400/40"></div>
        </div>
      </div>

      <!-- Columna derecha: pilares interactivos -->
      <PhilosophyPillars pillars={pillars} client:visible />

    </div>
  </div>
</section>
