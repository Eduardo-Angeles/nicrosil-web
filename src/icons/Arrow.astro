---
/**
 * Arrow icon — right-pointing arrow used in CTA buttons and links.
 * Renders an inline SVG so it inherits `currentColor` from its parent.
 *
 * Props:
 *   size  — pixel size (default: 15)
 *   class — extra CSS classes (e.g. "transition-transform group-hover:translate-x-0.5")
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 15, class: className = "" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  class={className}
>
  <path d="M5 12h14M12 5l7 7-7 7" />
</svg>
